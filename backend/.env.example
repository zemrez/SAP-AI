# SAP Connection
SAP_BASE_URL=https://your-sap-host:port/sap/opu/odata/sap
SAP_USERNAME=your_sap_user
SAP_PASSWORD=your_sap_password
SAP_CLIENT=100

# LLM Provider: "gemini" or "openai"
LLM_PROVIDER=gemini

# API Keys (set the one matching LLM_PROVIDER)
GEMINI_API_KEY=
OPENAI_API_KEY=

# App
APP_HOST=0.0.0.0
APP_PORT=8011
